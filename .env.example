# =============================================================================
# Nzamy Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Backend Mode (set to "supabase" to use real backend)
NEXT_PUBLIC_NZAMY_WORKFLOW_BACKEND=supabase

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# n8n Webhook URLs (your self-hosted n8n)
N8N_WEBHOOK_BASE_URL=http://your-n8n:5678/webhook
N8N_WEBHOOK_NEW_USER=http://your-n8n:5678/webhook/new-user
N8N_WEBHOOK_NEW_REQUEST=http://your-n8n:5678/webhook/new-request
N8N_WEBHOOK_PAYMENT=http://your-n8n:5678/webhook/payment

# Evolution API (WhatsApp) - Self-hosted
EVOLUTION_API_URL=http://your-evolution-api:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=nzamy

# Payment Gateway (configure when ready)
# PAYMENT_GATEWAY_API_KEY=
# PAYMENT_GATEWAY_SECRET_KEY=
# PAYMENT_GATEWAY_WEBHOOK_SECRET=

# AI (routed through n8n, no direct keys needed)
# N8N handles all AI provider keys internally
